<Window x:Class="TaskApp.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача" Height="350" Width="300" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="10">
        <TextBlock Text="Название:" />
        <TextBox x:Name="TitleBox" Margin="0,0,0,10" />

        <TextBlock Text="Описание:" />
        <TextBox x:Name="DescBox" Height="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" />

        <TextBlock Text="Исполнитель:" />
        <TextBox x:Name="AssigneeBox" Margin="0,0,0,10" />

        <TextBlock Text="Статус:" />
        <ComboBox x:Name="StatusCombo" Margin="0,0,0,10">
            <ComboBoxItem Content="Новая" IsSelected="True"/>
            <ComboBoxItem Content="В процессе"/>
            <ComboBoxItem Content="Выполнена"/>
        </ComboBox>

        <TextBlock Text="Срок:" />
        <DatePicker x:Name="DueDatePicker" Margin="0,0,0,20" />

        <Button Content="Сохранить" Click="Save_Click" Height="30" Background="#007ACC" Foreground="White" />
    </StackPanel>
</Window>