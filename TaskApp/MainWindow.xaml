<Window x:Class="TaskApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет задач команды" Height="500" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить задачу" Click="Add_Click" Width="120" Margin="0,0,10,0"/>
            <Button Content="Изменить" Click="Edit_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Удалить" Click="Delete_Click" Width="80" Margin="0,0,20,0"/>

            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="SearchBox" Width="100" TextChanged="Filter_Changed" Margin="0,0,10,0"/>

            <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="FilterStatusCombo" Width="100" SelectionChanged="Filter_Changed" Margin="0,0,10,0">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="Новая"/>
                <ComboBoxItem Content="В процессе"/>
                <ComboBoxItem Content="Выполнена"/>
            </ComboBox>

            <TextBlock Text="Исполнитель:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="FilterAssigneeBox" Width="100" TextChanged="Filter_Changed"/>
        </StackPanel>

        <DataGrid x:Name="TasksGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  CanUserSortColumns="True">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{Binding RowColor}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="150"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="200"/>
                <DataGridTextColumn Header="Исполнитель" Binding="{Binding Assignee}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Срок" Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatsText" Grid.Row="2" Margin="0,10,0,0" FontWeight="Bold" TextWrapping="Wrap" />
    </Grid>
</Window>